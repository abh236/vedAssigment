# ── Server ────────────────────────────────────────────────────────────────
PORT=4000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vedaai?retryWrites=true&w=majority

# ── Redis (optional — BullMQ job queue) ───────────────────────────────────
# Leave empty to use inline job runner (works fine without Redis)
REDIS_URL=

# ── AI Keys (at least one recommended) ────────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (FREE): https://console.groq.com/keys
GROQ_API_KEY=

# ── Frontend URL (set to your Vercel/Netlify URL after deploying frontend) ─
FRONTEND_URL=https://your-frontend.vercel.app
